/*全局*/
/*滚动条*/
QScrollBar:vertical {
    margin: 40px 0px 40px 0px;
    background-color: #ffffff;
    border: 0px;
    width: 40px;
}

QScrollBar::handle:vertical
{
background-color:#5b5b5b;
border-radius:1px;
width:40px;
}

QScrollBar::sub-line:vertical
{
subcontrol-position:top;
subcontrol-origin:margin;
height:40px;
}

QScrollBar::add-line:vertical
{
subcontrol-position:bottom;
subcontrol-origin:margin;
height:40px;
}

QScrollBar::up-arrow:vertical
{
width:12px;
height:6px;
}

QScrollBar::down-arrow:vertical
{
width:12px;
height:6px;
}

QScrollBar::sub-page:vertical,QScrollBar::add-page:vertical
{
background-color:#ffffff;
}


EditableTextWidget QLabel {
    font-family: "Microsoft YaHei UI";
    font-size: 55px;
}

EditableTextWidget QLineEdit {
    font-family: "Microsoft YaHei UI";
    font-size: 55px;
}

ContainerChildWindow EditableTextWidget QLabel,
PythonPluginChildWindow EditableTextWidget QLabel {
    font-family: "Microsoft YaHei UI";
    font-size: 55px;
}
ContainerChildWindow EditableTextWidget QLineEdit,
PythonPluginChildWindow EditableTextWidget QLineEdit {
    font-family: "Microsoft YaHei UI";
    font-size: 55px;
}

QFormLayout {
    margin: 2px;
}

/*主界面*/
QWidget#mainWindow {
    background-color: rgb(208, 204, 193);
}

QWidget#leftWidget {
    background-color: rgb(220, 220, 220);
    border-radius: 2px;
}

QWidget#stackedChildWidget {
    border-radius: 2px;
    background-color: rgb(22, 77, 160);
    /*    background-color: #9bb9d5;*/
}


QGroupBox#groupBoxSettings,
QGroupBox#groupBoxMenus {
    border: 2px solid black;
}

