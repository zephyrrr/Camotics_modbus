QGroupBox#groupBoxMenus {
    border: 0px solid gray;
    background-color: rgb(35, 25, 21);
}
QGroupBox#groupBoxMenus::title {
    subcontrol-origin: top left;
    subcontrol-position: top left;
    padding: 0 3px 0 3px;
    border: none;
    background-color: transparent;
    color: transparent;
}

/*QGroupBox#groupBoxMenus QPushButton,*/
QWidget#mainMenuWidget QPushButton {
    border-image: url(:/resources/image/menu_main.png);
    color: white;
    margin-left: 5px;
    margin-right: 5px;
    height: 68px;
/*    background-color: rgb(225, 225, 225);
    border-left: 2px solid white;
    border-top: 2px solid white;
    border-right: 2px solid black;
    border-bottom: 2px solid black;*/
    font-family: "Microsoft YaHei UI";
    font-size: 32px;
}

QFrame#mainMenuWidget QPushButton:checked {
    border-image: url(:/resources/image/menu_main_active.png) 0 0 0 0 stretch stretch;
    color: white;
}

QFrame#subMenuWidget QToolButton {
    border-image: url(:/resources/image/menu_sub.png) 0 0 0 0 stretch stretch;
    color: rgb(200, 200, 200);
    margin-left: 5px;
    margin-right: 5px;
    margin-bottom: 5px;
    height: 66px;
    /*    background-color: rgb(225, 225, 225);*/
    /*    border-left: 2px solid white;
    border-top: 2px solid white;
    border-right: 2px solid black;
    border-bottom: 2px solid black;*/
    font-family: "Microsoft YaHei UI";
    font-size: 30px;
}
QFrame#subMenuWidget QToolButton:checked {
    border-image: url(:/resources/image/menu_sub_active.png) 0 0 0 0 stretch stretch;
    color: white;
}
QLabel#labelMenuSepartor {
    border-image: url(:/resources/image/menu_separator.png) 0 0 0 0 stretch stretch;
}

/*顶部信息栏*/
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton {
    border-image: url(:/resources/image/topinfo_shortcut_btn.png) 0 0 0 0 stretch stretch;
    /*    background-repeat: repeat;
    background-position: center;*/
    width: 120px;
    height: 40px;
    font-family: Microsoft YaHei UI;
    font-size: 22px;
    font-weight: bold;
    font-style: normal;
    color: rgb(255, 255, 255);
    /*    border: 0px;*/
    /*    border-style: outset;
    border-width: 2px;
    border-radius: 0px;
    border-color: beige;*/
    margin: 0px;
    padding: 0px;
}

QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton:pressed {
    color: black;
    background-color: rgb(170, 85, 255);
    border: 2px solid black;
}
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnT1:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnST:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnG24:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnYouWen:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnYouWei:checked,
QWidget#topinfobar QWidget#topinfobar_shortcut QPushButton#btnHuoYan:checked {
    color: black;
    border-style: inset;
}

QMenu#btnCoorMenu {
    background-color: rgb(100, 165, 255);
    border: 1px solid #ccc;
    border-radius: 5px;
    padding: 5px;
    font-family: Microsoft YaHei UI;
    font-size: 40px;
    font-weight: bold;
    font-style: normal;
    color: white;
}

QMenu#btnCoorMenu::item {
    padding: 5px;
}

QMenu#btnCoorMenu::item:selected {
    background-color: #333;
    color: white;
}

QWidget#topinfobar QWidget#topinfobar_pos {
    border-image: url(:/resources/image/topinfo_pos.png);
    background-repeat: no-repeat;
    background-position: center;
    min-height: 250px;
    /*    width: 412px;
    height: 242px;*/
}
QWidget#topinfobar QWidget#topinfobar_pos_uw {
    border-image: url(:/resources/image/topinfo_pos_uw.png);
    background-repeat: repeat;
    background-position: center;
    min-height: 30px;
}

QWidget#topinfobar QLabel#xLabel {
    margin-top: 8px;
    margin-left: 40px;
    color: white;
    font-family: Consolas;
    font-weight: bold;
    font-size: 55px;
    vertical-align: bottom;
    /*    border-right: 1px solid black;
    border-top: 1px solid black;*/
}

QWidget#topinfobar QLabel#yLabel,
QWidget#topinfobar QLabel#zLabel {
    margin-top: 8px;
    margin-left: 0px;
    color: white;
    font-family: Consolas;
    font-weight: bold;
    font-size: 55px;
    vertical-align: bottom;
    /*    border: black;
    border-right: 1px solid black;
    padding-right: 1px;*/
}

QWidget#topinfobar QLabel#wLabel,
QWidget#topinfobar QLabel#uLabel {
    margin-top: -5px;
    margin-left: 0px;
    color: white;
    font-family: Consolas;
    font-weight: normal;
    font-size: 22px;
    vertical-align: bottom;
    /*    border-top: 1px solid black;*/
    padding-right: 5px;
    /*    max-height: 30px;*/
}

QWidget#topinfobar QFrame#loran {
    border-image: url(:/resources/image/topinfo_loran.png) 0 0 0 0 stretch stretch;
    background-repeat: repeat;
    background-position: center;
    min-height: 250px;
    max-height: 250px;
    min-width: 250px;
    max-width: 250px;
}
QWidget#topinfobar QFrame#loran QGraphicsView {
    background: transparent;
    border: none;
}

QWidget #topinfobar QLabel#label_loran {
/*    background-image: url(:/resources/image/topinfo_loran_name.png);*/
    border-image: url(:/resources/image/topinfo_loran_name.png) 0 0 0 0 stretch stretch;
    background-repeat: no-repeat;
    background-position: center;
    min-height: 30px;
    font-family: Microsoft YaHei UI;
    font-size: 15px;
    font-weight: bold;
    font-style: normal;
    /*    color: transparent;*/
}

QWidget#topinfobar QFrame#displayz {
    border-image: url(:/resources/image/topinfo_displayz.png) 0 0 0 0 stretch stretch;
    background-repeat: no-repeat;
    background-position: center;
    min-height: 250px;
    max-height: 250px;
    min-width: 400px;
    max-width: 400px;
}

QWidget#topinfobar QFrame#displayz QGraphicsView {
    background: transparent;
    border: none;
}

QWidget#topinfobar QLabel#label_displayz {
    border-image: url(:/resources/image/topinfo_displayz_name.png) 0 0 0 0 stretch stretch;
    background-repeat: no-repeat;
    background-position: center;
    min-height: 30px;
    font-family: Microsoft YaHei UI;
    font-size: 15px;
    font-weight: bold;
    font-style: normal;
}

QWidget#topinfobar QFrame#frame_files {
    border-image: url(:/resources/image/topinfo_number_files.png) 0 0 0 0 stretch stretch;
    background-repeat: repeat;
    min-height: 30px;
    max-height: 30px;
}

QWidget#topinfobar QFrame#frame_numbers {
    border-image: url(:/resources/image/topinfo_number_number.png) 0 0 0 0 stretch stretch;
    background-repeat: repeat;
    padding-left: 10px;
    padding-right: 10px;
}

