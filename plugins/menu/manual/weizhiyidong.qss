ZuoBiaoXiSheZiForm QTabBar::tab,
WeiZhiJiYiForm QTabBar::tab,
WeiZhiYiDongForm QTabBar::tab,
NcEditForm QTabBar::tab,
RunAutoForm QTabBar::tab {
    background-color: rgb(39, 124, 242);
    color: rgb(208, 204, 193);
    /*    border: 2px solid;*/
    /*border-bottom-color: #C2C7CB;*/ /* same as the pane color */
    /*border-top-left-radius: 2px;*/
    border-radius: 5px;
    font-weight: bold;
}

ZuoBiaoXiSheZiForm QTabBar::tab,
WeiZhiJiYiForm QTabBar::tab {
    min-width: 10px;
    padding: 5px;
}

WeiZhiYiDongForm QTabBar::tab {
    min-width: 200px;
    padding: 20px;
}

NcEditForm QTabBar::tab {
    min-width: 200px;
    padding: 0px;
}
RunAutoForm QTabBar::tab {
    min-width: 400px;
    padding: 20px;
}

ZuoBiaoXiSheZiForm QTabBar::tab:selected,
WeiZhiJiYiForm QTabBar::tab:selected,
WeiZhiYiDongForm QTabBar::tab:selected,
NcEditForm QTabBar::tab:selected,
RunAutoForm QTabBar::tab:selected {
    background-color: rgb(65, 145, 253);
    color: ghostwhite;
}

QMessageBox {
    font-family: "Microsoft YaHei UI";
    font-size: 40px;
}
QMessageBox QPushButton{
    font-family: "Microsoft YaHei UI";
    font-size: 30px;
}
QMessageBox QPushButton:focus {
    font: bold 30px;
    color: white;
    background-color: rgb(170, 85, 255);
}

