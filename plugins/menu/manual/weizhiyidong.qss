QWidget#leftWidget QLabel#lblResultMessage {
    background-color: rgb(35,25,21);
    border: 0px solid rgb(253, 253, 253);
    border-right: 0px;
    /*    border-image: url(:/resources/image/status_background.png) 0 0 0 0 stretch stretch;*/
