from PythonQt.QtGui import *

btn = window.findChild(QPushButton, "btnX")
edit = window.findChild(QLineEdit, "inX")

def appendLine(b):   
    edit.setText("0.000")
    
# connect the button's clicked signal to our python method
edit.connect('focusChanged(bool)',  lambda b: b and edit.setText("0.000"))
